# Firebase Admin SDK Configuration
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# Copy this file to .env and fill in actual values

# Firebase Service Account (จาก Google Cloud Console → IAM → Service Accounts)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Admin Configuration
# รายชื่ออีเมลแอดมิน คั่นด้วย comma (,)
ADMIN_EMAILS=admin@example.com

# Server Configuration
NODE_ENV=development
PORT=3000

# CORS Configuration
# origins ที่อนุญาต คั่นด้วย comma (,)
ALLOWED_ORIGINS=http://localhost:5500,http://localhost:5501,http://127.0.0.1:5500
